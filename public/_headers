# Cloudflare Pages headers

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: interest-cohort=(), camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://cloudflareinsights.com; frame-ancestors 'self'; base-uri 'self'; object-src 'none'; form-action 'self'
  Access-Control-Allow-Origin: *
  # Edge-cache HTML. Two facts make this both work AND stay fresh:
  #  1. CF treats text/html as DYNAMIC and ignores s-maxage UNLESS a Cache Rule
  #     marks the zone "cache eligible / respect origin TTL" (one exists on this
  #     zone's cache phase, ruleId 273b8576). With it, the edge honours s-maxage.
  #  2. A CF Pages deploy does NOT purge that rule's edge entries, so freshness is
  #     handled by .github/workflows/purge-on-deploy.yml: it fires on CF Pages'
  #     GitHub check run completing for main and purge_everything's the zone, so a
  #     deployed change is live within ~1 min regardless of the TTL below.
  # Because purge-on-deploy guarantees freshness, s-maxage is LONG (1 day) to
  # maximise the cache-hit ratio between deploys. Browsers still revalidate
  # (max-age=0). If you ever disable that purge workflow, drop s-maxage back to
  # ~600. Immutable /_astro/* keep their 1yr rule below.
  Cache-Control: public, max-age=0, s-maxage=86400, stale-while-revalidate=86400
  Link: </llms.txt>; rel="alternate"; type="text/plain"; title="llms.txt", </.well-known/agent.json>; rel="alternate"; type="application/json"; title="agent-card", </.well-known/api-catalog>; rel="api-catalog", </sitemap-index.xml>; rel="sitemap"

# Hashed assets are immutable
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/og/*
  Cache-Control: public, max-age=86400

# Embeddable SVG badges (HuggingFace/GitHub READMEs). Long cache; deploy-purge busts it.
/badge/*
  Content-Type: image/svg+xml; charset=utf-8
  Cache-Control: public, max-age=86400

/.well-known/agent.json
  Content-Type: application/json; charset=utf-8

/.well-known/api-catalog
  Content-Type: application/linkset+json; charset=utf-8
  Cache-Control: public, max-age=3600

/api/*
  Cache-Control: public, max-age=3600

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
