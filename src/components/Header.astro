---
import { getLangFromUrl, useTranslations, localizedPath } from "@/i18n/utils";
import type { Lang } from "@/i18n/ui";
interface Props {
  lang?: Lang;
}
// Prefer the explicit prop from Base; only fall back to URL derivation (which
// loses the locale prefix at build time) when rendered without one.
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// Nav targets are English canonical pages (only the homepage is translated so
// far); labels are localized. Logo + switcher are locale-aware.
const links = [
  { href: "/can-i-run", label: t("nav.models") },
  { href: "/best-llm-for", label: t("nav.devices") },
  { href: "/compare", label: t("nav.compare") },
  { href: "/guides", label: t("nav.guides") },
  { href: "/rig", label: t("nav.rig") },
  { href: "/methodology", label: t("nav.methodology") },
];
// Active-nav highlight: match the current path against each canonical link
// (locale prefix stripped) so the right pill gets `.on`.
const path = Astro.url.pathname.replace(/^\/(es)(?=\/|$)/, "") || "/";
const isActive = (href: string) => href !== "/" && path.startsWith(href);
---

<!--
  Gauge·Glass floating capsule header. The <header> banner landmark IS the
  sticky glass pill (.gh) so it floats over scrolling content; the mobile nav
  is an absolute dropdown beneath it. --shell matches the site content column
  (max-w-6xl = 72rem) so the capsule aligns to content. Semantics, i18n, focus
  rings, aria state, and the delegated script are all preserved from before.
-->
<header class="gh glass spotlight" style="--shell: 72rem" data-glass-header>
  <a
    href={localizedPath("/", lang)}
    class="gh-brand rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]"
  >
    <span class="sq">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="3" y="7" width="15.5" height="10" rx="3" fill="none" stroke="currentColor" stroke-width="2"></rect>
        <rect x="5" y="9" width="9" height="6" rx="1.4" fill="var(--color-verdict-yes)"></rect>
        <rect x="20" y="10.2" width="1.8" height="3.6" rx="0.9" fill="currentColor"></rect>
        <path d="M12.2 6.6 8.2 12.8 11 12.8 10 17.4 14.6 11 11.8 11Z" fill="oklch(0.18 0.02 272)"></path>
      </svg>
    </span>
    <span class="whitespace-nowrap">localmodel<span class="run">.run</span></span>
  </a>

  <span class="gh-status" aria-hidden="true">
    <span class="dot"></span>
    model compatibility
  </span>

  <nav class="gh-nav hidden sm:flex" aria-label="Primary">
    {links.map((l) => (
      <a
        href={l.href}
        class:list={[isActive(l.href) && "on", "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]"]}
        aria-current={isActive(l.href) ? "page" : undefined}
      >
        {l.label}
      </a>
    ))}
  </nav>

  <button
    id="theme-toggle"
    type="button"
    class="icon-btn p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]"
    aria-label="Toggle theme"
  >
    <svg class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
    <svg class="block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z"></path></svg>
  </button>
  <button
    id="mobile-menu-btn"
    type="button"
    class="icon-btn p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)] sm:hidden"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-nav"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"></path></svg>
  </button>

  <!-- Mobile nav: absolute dropdown beneath the capsule (cheap-tier glass) -->
  <nav
    id="mobile-nav"
    aria-label="Primary mobile"
    class="glass-lite absolute left-0 right-0 top-full mt-2 hidden px-3 py-2 sm:hidden"
  >
    <ul class="flex flex-col">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={["block rounded-md px-3 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]", isActive(l.href) ? "text-[var(--brand-ink)]" : "text-muted-foreground"]}
            aria-current={isActive(l.href) ? "page" : undefined}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script is:inline>
  // Delegated on document so the listeners survive view-transition swaps.
  (function () {
    if (window.__lmrHeaderBound) return;
    window.__lmrHeaderBound = true;
    document.addEventListener("click", function (e) {
      var el = e.target;
      if (!(el instanceof Element)) return;
      if (el.closest("#theme-toggle")) {
        var root = document.documentElement;
        var dark = root.classList.toggle("dark");
        root.classList.toggle("light", !dark);
        try {
          localStorage.setItem("theme", dark ? "dark" : "light");
        } catch (_e) {
          /* localStorage unavailable (private mode); ignore */
        }
        return;
      }
      var btn = el.closest("#mobile-menu-btn");
      if (btn) {
        var panel = document.getElementById("mobile-nav");
        if (!panel) return;
        var closed = panel.classList.toggle("hidden");
        btn.setAttribute("aria-expanded", String(!closed));
        btn.setAttribute("aria-label", closed ? "Open menu" : "Close menu");
      }
    });
  })();
</script>
