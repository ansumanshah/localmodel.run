---
import { getLangFromUrl, useTranslations, localizedPath } from "@/i18n/utils";
import type { Lang } from "@/i18n/ui";
interface Props {
  lang?: Lang;
}
// Prefer the explicit prop from Base; only fall back to URL derivation (which
// loses the locale prefix at build time) when rendered without one.
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// Nav targets are English canonical pages (only the homepage is translated so
// far); labels are localized. Logo + switcher are locale-aware.
const links = [
  { href: "/can-i-run", label: t("nav.models") },
  { href: "/best-llm-for", label: t("nav.devices") },
  { href: "/leaderboard", label: t("nav.leaderboard") },
  { href: "/compare", label: t("nav.compare") },
  { href: "/tools", label: t("nav.tools") },
  { href: "/guides", label: t("nav.guides") },
  { href: "/rig", label: t("nav.rig") },
  { href: "/methodology", label: t("nav.methodology") },
];
// Active-nav highlight: match the current path against each canonical link
// (locale prefix stripped) so the right pill gets `.on`.
const path = Astro.url.pathname.replace(/^\/(es)(?=\/|$)/, "") || "/";
const isActive = (href: string) => href !== "/" && path.startsWith(href);
---

<!--
  The Calibrated Instrument header: a flush control-panel bezel. The <header>
  banner landmark IS the sticky bar (.gh), opaque with a ruler-tick contact
  edge, so content scrolls cleanly beneath it; the mobile nav is an absolute
  dropdown under the bezel. Class names are historical (frozen, see
  docs/naming-conventions.md). Semantics, i18n, focus rings, aria state, and
  the delegated script are all preserved from before.
-->
<header class="gh glass" style="--shell: 64rem" data-glass-header>
  <a
    href={localizedPath("/", lang)}
    class="gh-brand rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]"
  >
    <span class="sq">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 19 A 9 9 0 0 1 21 19" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"></path>
        <line x1="12" y1="19" x2="14.5" y2="11.4" stroke="var(--color-brand)" stroke-width="2.2" stroke-linecap="round"></line>
        <circle cx="12" cy="19" r="1.9" fill="var(--color-brand)"></circle>
      </svg>
    </span>
    <span class="whitespace-nowrap">localmodel<span class="run">.run</span></span>
  </a>

  <nav class="gh-nav hidden sm:flex" aria-label="Primary">
    {links.map((l) => (
      <a
        href={l.href}
        class:list={[isActive(l.href) && "on", "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]"]}
        aria-current={isActive(l.href) ? "page" : undefined}
      >
        {l.label}
      </a>
    ))}
  </nav>

  <button
    id="theme-toggle"
    type="button"
    data-theme-toggle
    class="icon-btn hidden min-h-[44px] min-w-[44px] items-center justify-center p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)] sm:inline-flex"
    aria-label="Toggle theme"
  >
    <svg class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
    <svg class="block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z"></path></svg>
  </button>
  <button
    id="mobile-menu-btn"
    type="button"
    class="icon-btn inline-flex min-h-[44px] min-w-[44px] items-center justify-center p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)] sm:hidden"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-nav"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"></path></svg>
  </button>

  <!-- Mobile nav: absolute dropdown beneath the bezel (matte plate) -->
  <nav
    id="mobile-nav"
    aria-label="Primary mobile"
    class="glass-lite absolute left-0 right-0 top-full mt-2 hidden px-3 py-2 sm:hidden"
  >
    <ul class="flex flex-col">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={["block rounded-md px-3 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]", isActive(l.href) ? "text-[var(--brand-ink)]" : "text-muted-foreground"]}
            aria-current={isActive(l.href) ? "page" : undefined}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="mt-1.5 border-t border-border pt-1.5">
      <button
        type="button"
        data-theme-toggle
        aria-label="Toggle theme"
        class="flex w-full items-center gap-2.5 rounded-md px-3 py-2.5 font-mono text-xs uppercase tracking-wider text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]"
      >
        <svg class="hidden dark:block" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
        <svg class="dark:hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z"></path></svg>
        <span class="dark:hidden">Dark theme</span>
        <span class="hidden dark:inline">Light theme</span>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  // Delegated on document so the listeners survive view-transition swaps.
  (function () {
    if (window.__lmrHeaderBound) return;
    window.__lmrHeaderBound = true;
    function closeMenu() {
      var panel = document.getElementById("mobile-nav");
      if (!panel || panel.classList.contains("hidden")) return;
      panel.classList.add("hidden");
      var mb = document.getElementById("mobile-menu-btn");
      if (mb) {
        mb.setAttribute("aria-expanded", "false");
        mb.setAttribute("aria-label", "Open menu");
      }
    }
    document.addEventListener("click", function (e) {
      var el = e.target;
      if (!(el instanceof Element)) return;
      if (el.closest("[data-theme-toggle]")) {
        var root = document.documentElement;
        var dark = root.classList.toggle("dark");
        root.classList.toggle("light", !dark);
        if (window.__setThemeColor) window.__setThemeColor(dark);
        try {
          localStorage.setItem("theme", dark ? "dark" : "light");
        } catch (_e) {
          /* localStorage unavailable (private mode); ignore */
        }
        return;
      }
      var panel = document.getElementById("mobile-nav");
      var btn = el.closest("#mobile-menu-btn");
      if (btn) {
        if (!panel) return;
        var closed = panel.classList.toggle("hidden");
        btn.setAttribute("aria-expanded", String(!closed));
        btn.setAttribute("aria-label", closed ? "Open menu" : "Close menu");
        return;
      }
      // Tap outside the open menu, or on one of its links, closes it.
      if (panel && !panel.classList.contains("hidden") && (!el.closest("#mobile-nav") || el.closest("#mobile-nav a"))) {
        closeMenu();
      }
    });
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeMenu();
    });
  })();
</script>
