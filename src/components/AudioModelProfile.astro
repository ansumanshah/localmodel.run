---
import VerdictBadge from "@/components/VerdictBadge.astro";
import EntityIcon from "@/components/EntityIcon.astro";
import Sources from "@/components/Sources.astro";
import { devices, categoryDevices, CATEGORY_LABEL, dedupeSources, meta } from "@/lib/data";
import { canRunModality, modalityNeed } from "@/lib/compute-mm";
import type { ModelRow, AudioSpec } from "@/data/types";

interface Props {
  model: ModelRow;
}
const { model } = Astro.props;
const spec = model.audio as AudioSpec;
const need = modalityNeed(model)!;
const paramLabel = model.params_b < 1 ? `${Math.round(model.params_b * 1000)}M` : `${model.params_b}B`;

const COMMERCIAL: Record<string, { label: string; cls: string }> = {
  yes: { label: "Commercial use OK", cls: "text-[var(--verdict-yes-fg)]" },
  conditional: { label: "Commercial use: conditional", cls: "text-[var(--verdict-tight-fg)]" },
  no: { label: "Non-commercial", cls: "text-[var(--verdict-no-fg)]" },
};
const commercial = model.commercial_use ? COMMERCIAL[model.commercial_use] : null;

const groups = categoryDevices();
const runnable = devices.filter((d) => canRunModality(model, d).verdict !== "no");
const minDevice = [...runnable].sort((a, b) => a.memory_gb - b.memory_gb)[0];
const sources = dedupeSources(model.sources, [need.source]);
---

<div class="mx-auto max-w-3xl px-4 py-8">
  <slot name="breadcrumbs" />

  <h1 class="flex items-center gap-3 text-balance text-3xl font-bold tracking-tight sm:text-4xl">
    <EntityIcon maker={model.family} size={28} class="text-muted-foreground" />
    <span>{model.name} requirements</span>
  </h1>
  <p class="mt-4 text-pretty text-lg text-muted-foreground">
    {spec.task} · {paramLabel} params · {spec.precision}{model.release ? ` · released ${model.release}` : ""}.
    {spec.cpu_ok
      ? "Light enough to run on CPU, no GPU required."
      : `Realistic minimum to run: ${minDevice ? minDevice.name : "a GPU"}.`}
  </p>

  {(model.license || commercial) && (
    <div class="mt-4 flex flex-wrap items-center gap-2 text-sm">
      {model.license && <span class="rounded-full border border-border bg-card px-3 py-1">{model.license}</span>}
      {commercial && <span class={`rounded-full border border-border bg-card px-3 py-1 font-medium ${commercial.cls}`}>{commercial.label}</span>}
    </div>
  )}
  {model.license_note && <p class="mt-2 text-xs text-muted-foreground">{model.license_note}</p>}

  <section class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
    {[
      { k: `Peak memory (${need.quantLabel})`, v: `~${need.neededGb} GB` },
      { k: "Runs on CPU", v: spec.cpu_ok ? "Yes" : "No" },
      { k: "Parameters", v: paramLabel },
      { k: "Type", v: spec.task },
    ].map((s) => (
      <dl class="rounded-xl border border-border bg-card p-4">
        <dt class="text-xs text-muted-foreground">{s.k}</dt>
        <dd class="mt-1 text-lg font-semibold">{s.v}</dd>
      </dl>
    ))}
  </section>

  <section class="mt-8">
    <h2 class="text-lg font-semibold">Run it</h2>
    <p class="mt-2 text-sm text-muted-foreground">
      {model.name} runs in {spec.tools.slice(0, -1).join(", ")}{spec.tools.length > 1 ? ` or ${spec.tools[spec.tools.length - 1]}` : spec.tools[0]} at {need.quantLabel}.
      {spec.cpu_ok
        ? " It runs CPU-only, and the smaller tiers are fast enough for real-time use on a laptop or phone."
        : " It needs a GPU (or Apple Silicon with enough unified memory)."}
    </p>
    <div class="mt-3 flex flex-wrap gap-2">
      {spec.tools.map((t) => (
        <span class="rounded-lg border border-border bg-card px-3 py-1.5 text-sm">{t}</span>
      ))}
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-lg font-semibold">Which devices can run {model.name}?</h2>
    <div class="mt-3 space-y-5">
      {Object.entries(groups).map(([cat, list]) => {
        const supported = list.length > 0 && spec.device_classes.includes(list[0].category);
        return (
          <div>
            <h3 class="mb-2 text-sm font-semibold text-muted-foreground">{CATEGORY_LABEL[cat] ?? cat}</h3>
            {supported ? (
              <ul class="grid gap-2 sm:grid-cols-2">
                {list.map((d) => {
                  const r = canRunModality(model, d);
                  return (
                    <li>
                      <a href={`/can-i-run/${model.id}/${d.id}`} class="flex items-center justify-between rounded-lg border border-border bg-card px-3 py-2 transition-colors hover:border-foreground/30">
                        <span class="flex min-w-0 items-center gap-2 text-sm">
                          <EntityIcon device={d.category} size={18} class="text-muted-foreground" />
                          <span class="truncate">{d.name}</span>
                        </span>
                        <VerdictBadge verdict={r.verdict} />
                      </a>
                    </li>
                  );
                })}
              </ul>
            ) : (
              <p class="text-sm text-muted-foreground">No mainstream local runtime for {model.name} on {CATEGORY_LABEL[cat] ?? cat} yet.</p>
            )}
          </div>
        );
      })}
    </div>
  </section>

  <slot />

  {model.notes && <p class="mt-8 rounded-lg border border-border bg-card p-4 text-sm text-muted-foreground">{model.notes}</p>}

  <Sources urls={sources} />

  <p class="mt-6 text-xs text-muted-foreground">
    Memory is a sourced peak-usage anchor at {need.quantLabel}{need.synthesis ? " (composed from reported sizes, not a single measurement)" : ""}, validated {meta.updated}. See <a href="/methodology" class="underline">methodology</a>.
  </p>
</div>
