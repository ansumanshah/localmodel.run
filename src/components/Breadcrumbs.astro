---
import type { BreadcrumbItem } from "@/lib/seo";
interface Props {
  items: BreadcrumbItem[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-5 text-sm text-muted-foreground">
  <ol class="flex flex-wrap items-center gap-1.5">
    {items.map((it, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && <span aria-hidden="true" class="opacity-50">/</span>}
        {i < items.length - 1 ? (
          <a href={it.url} class="transition-colors hover:text-foreground">{it.name}</a>
        ) : (
          <span class="text-foreground" aria-current="page">{it.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
