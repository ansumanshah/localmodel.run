---
import Base from "@/layouts/Base.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Command from "@/components/Command.astro";
import Sources from "@/components/Sources.astro";
import EntityIcon from "@/components/EntityIcon.astro";
import { tools, platformLabel, dedupeSources, meta } from "@/lib/data";
import { breadcrumbLd, faqLd, techArticleLd, truncate, type FaqItem } from "@/lib/seo";

const path = "/tools";
const title = "Best tools to run LLMs locally, by platform · localmodel.run";
const description = truncate(
  "The right local-AI runtime for each platform: MLX and Ollama on Mac, CUDA on Windows, vLLM for serving on Linux, Apple Foundation Models and PocketPal on phones. With versions and commands.",
);

const faqs: FaqItem[] = [
  { q: "Is vLLM good for Mac?", a: "No. vLLM is a CUDA/Linux serving engine built for throughput across many requests. On Apple Silicon use MLX (mlx-lm) or Ollama/LM Studio instead." },
  { q: "Ollama or LM Studio?", a: "LM Studio is the friendliest GUI and ships MLX on Apple Silicon. Ollama is a scriptable CLI/server that is great for integrating local models into tools. Both support GGUF models; on Apple Silicon, LM Studio defaults to its MLX backend instead of llama.cpp." },
  { q: "What is the fastest way to run a model on Apple Silicon?", a: "mlx-lm. Same model, same quant, consistently higher tokens per second than Ollama's llama.cpp Metal backend on M-series chips. Ollama has an MLX backend in preview that narrows the gap, but mlx-lm still leads. LM Studio can use the same MLX backend if you want a GUI." },
];

const sources = dedupeSources(...tools.map((t) => t.sources));
const jsonLd = [
  breadcrumbLd([{ name: "Home", url: "/" }, { name: "Tools", url: path }], Astro.site!.href),
  techArticleLd({ headline: "Best tool to run LLMs locally, per platform", description, url: path, origin: Astro.site!.href, dateModified: meta.updated, sources }),
  faqLd(faqs),
];
---

<Base title={title} description={description} path={path} jsonLd={jsonLd} ogType="article">
  <!-- Intro band: themed header, no grid/scanline behind content -->
  <div class="relative overflow-hidden border-b border-border bg-[color-mix(in_oklch,var(--color-brand)_3%,var(--background))]">
    <div class="mx-auto max-w-3xl px-4 py-10">
      <Breadcrumbs items={[{ name: "Home", url: "/" }, { name: "Tools", url: path }]} />

      <p class="bp-eyebrow mt-4">
        <span class="bp-dot" aria-hidden="true"></span>
        {tools.length} platforms &middot; runtimes guide
      </p>
      <h1 class="mt-3 text-balance text-3xl font-bold tracking-tight sm:text-4xl">
        Best tool to run LLMs <span class="bp-accent">locally</span>
      </h1>
      <p class="mt-4 text-pretty text-lg text-muted-foreground">
        The runtime that is fastest on a Mac will fail to start on Windows. Here is what to install, who each tool is actually for, and the one mistake people make on each platform.
      </p>

      <div class="bp-wire mt-6" aria-hidden="true"></div>

      <nav class="mt-4 flex flex-wrap gap-2" aria-label="Jump to platform">
        {tools.map((t) => (
          <a
            href={`#${t.platform}`}
            class="inline-flex items-center gap-1.5 rounded-full border border-[color-mix(in_oklch,var(--color-brand)_25%,transparent)] bg-[color-mix(in_oklch,var(--color-brand)_6%,transparent)] px-3 py-1.5 font-mono text-xs tracking-wide text-[var(--color-brand)] transition-colors hover:bg-[color-mix(in_oklch,var(--color-brand)_12%,transparent)]"
          >
            <EntityIcon os={t.platform} size={12} />
            {platformLabel(t.platform)}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <div class="mx-auto max-w-3xl px-4 py-8">
    <div class="space-y-10">
      {tools.map((t) => (
        <section id={t.platform} class="scroll-mt-20">
          <!-- Platform header -->
          <div class="bp-panel overflow-hidden">
            <div class="bp-panel-header">
              <span class="bp-panel-label flex items-center gap-1.5">
                <EntityIcon os={t.platform} size={11} />
                {platformLabel(t.platform)}
              </span>
              <span class="bp-panel-label opacity-60">runtime guide</span>
            </div>

            <!-- Pick cards -->
            <div class="grid gap-3 p-4 sm:grid-cols-2">
              <div class="rounded-lg border border-[color-mix(in_oklch,var(--color-brand)_30%,transparent)] bg-[color-mix(in_oklch,var(--color-brand)_8%,transparent)] p-4">
                <div class="bp-stat-label text-[var(--color-brand)]">Beginner pick</div>
                <div class="mt-1.5 text-lg font-semibold">{t.beginner.name}</div>
                <p class="mt-1 text-sm text-muted-foreground">{t.beginner.why}</p>
              </div>
              <div class="rounded-lg border border-border bg-card p-4">
                <div class="bp-stat-label">Power user</div>
                <div class="mt-1.5 text-lg font-semibold">{t.power.name}</div>
                <p class="mt-1 text-sm text-muted-foreground">{t.power.why}</p>
              </div>
            </div>

            {(t.power.command || t.beginner.command) && (
              <div class="border-t border-[color-mix(in_oklch,var(--color-brand)_15%,transparent)] px-4 pb-4 pt-3">
                <Command code={(t.power.command || t.beginner.command)!} />
              </div>
            )}

            <!-- Runtime table -->
            <div class="border-t border-[color-mix(in_oklch,var(--color-brand)_15%,transparent)]">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-[color-mix(in_oklch,var(--color-brand)_5%,transparent)]">
                    <th scope="col" class="bp-stat-label px-4 py-2 text-left font-medium">Runtime</th>
                    <th scope="col" class="bp-stat-label px-4 py-2 text-left font-medium">What it is</th>
                    <th scope="col" class="bp-stat-label px-4 py-2 text-left font-medium">Status</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-border">
                  {t.runtimes.map((r) => (
                    <tr class="transition-colors hover:bg-[color-mix(in_oklch,var(--color-brand)_4%,transparent)]">
                      <td class="px-4 py-2.5"><a href={r.url} rel="noopener nofollow" class="font-medium text-foreground hover:text-[var(--color-brand)] hover:underline">{r.name}</a></td>
                      <td class="px-4 py-2.5 text-muted-foreground">{r.what}</td>
                      <td class="px-4 py-2.5 text-muted-foreground">{r.status}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <!-- Gotcha + ceiling -->
            <div class="border-t border-[color-mix(in_oklch,var(--color-brand)_15%,transparent)] bg-[color-mix(in_oklch,var(--color-verdict-tight)_6%,transparent)] px-4 py-3 text-sm">
              <strong class="text-foreground">Gotcha:</strong> <span class="text-muted-foreground">{t.gotcha}</span>
            </div>
            <div class="bp-panel-footer">
              <span class="bp-panel-label">Realistic ceiling</span>
              <span class="font-mono text-xs text-muted-foreground">{t.ceiling}</span>
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- FAQ -->
    <section class="mt-12">
      <p class="bp-eyebrow mb-3"><span class="bp-dot" aria-hidden="true"></span>FAQ</p>
      <div class="bp-panel divide-y divide-border">
        {faqs.map((f) => (
          <div class="p-4">
            <p class="font-medium">{f.q}</p>
            <p class="mt-2 text-sm text-muted-foreground">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <Sources urls={sources} />
  </div>
</Base>
