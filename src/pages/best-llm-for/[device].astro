---
import Base from "@/layouts/Base.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import VerdictBadge from "@/components/VerdictBadge.astro";
import Sources from "@/components/Sources.astro";
import EntityIcon from "@/components/EntityIcon.astro";
import {
  devices,
  modelsBySize,
  getTool,
  devicePlatform,
  platformLabel,
  dedupeSources,
  meta,
} from "@/lib/data";
import { canRun, usableGb, QUANT_LABEL } from "@/lib/compute";
import {
  breadcrumbLd,
  faqLd,
  howToLd,
  itemListLd,
  techArticleLd,
  truncate,
  type FaqItem,
} from "@/lib/seo";

export function getStaticPaths() {
  return devices.map((device) => ({ params: { device: device.id }, props: { device } }));
}

const { device } = Astro.props;
const usable = usableGb(device);
const platform = devicePlatform(device);
const tool = getTool(platform);

const ranked = modelsBySize
  .map((m) => ({ model: m, result: canRun(m, device) }))
  .sort((a, b) => b.model.params_b - a.model.params_b);
const fitting = ranked.filter((r) => r.result.verdict !== "no");
const notFitting = ranked.filter((r) => r.result.verdict === "no");
// "Best" pick = the highest-quality model that runs comfortably (LMArena Elo where
// we have it), not just the biggest. Falls back to fast-and-fitting, then anything that fits.
const topPick =
  [...fitting]
    .filter((r) => r.result.verdict === "yes" && r.model.arena_elo != null)
    .sort((a, b) => (b.model.arena_elo ?? 0) - (a.model.arena_elo ?? 0))[0] ??
  fitting.find((r) => r.result.speed === "fast" || r.result.speed === "ok") ??
  fitting[0];

const path = `/best-llm-for/${device.id}`;
const year = new Date(meta.updated).getFullYear();
const title = `Best local LLMs for ${device.name} (${year}) · localmodel.run`;
const description = truncate(
  `${device.name} has ~${usable} GB usable and runs ${fitting.length} of ${ranked.length} popular models locally.${topPick ? ` Top pick: ${topPick.model.name}.` : ""} Best tool: ${tool?.beginner.name ?? "Ollama"}. Ranked list with sizes and commands.`,
);

const faqs: FaqItem[] = [
  {
    q: `What is the best local LLM for ${device.name}?`,
    a: topPick
      ? `${topPick.model.name} is the strongest model that runs comfortably, using ~${topPick.result.estimate?.totalGb} GB at ${topPick.result.quant ? QUANT_LABEL[topPick.result.quant] : "Q4_K_M"} of the ~${usable} GB usable on ${device.name}.`
      : `${device.name} has limited memory; stick to 1B-4B models at Q4_K_M.`,
  },
  {
    q: `How much of ${device.name}'s memory can I use for a model?`,
    a: `About ${usable} GB. ${device.memory_type === "unified" && device.category === "mac" ? "Apple Silicon shares one unified memory pool; roughly 66-75% is available to the GPU for model weights, the rest is reserved for macOS." : device.memory_type === "vram" ? "On a discrete GPU, leave ~1 GB of VRAM for the driver and display." : "On a CPU-only machine, leave headroom for the OS and apps."}`,
  },
  {
    q: `Which tool should I use on ${platformLabel(platform)}?`,
    a: tool ? `${tool.beginner.name} (${tool.beginner.why}) or ${tool.power.name} for speed. ${tool.gotcha}` : "Ollama or LM Studio.",
  },
];

const sources = dedupeSources(device.sources, tool?.sources ?? [], topPick?.model.sources ?? []);
const jsonLd = [
  breadcrumbLd(
    [
      { name: "Home", url: "/" },
      { name: "Devices", url: "/best-llm-for" },
      { name: device.name, url: path },
    ],
    Astro.site!.href,
  ),
  techArticleLd({
    headline: `Best local LLMs for ${device.name}`,
    description,
    url: path,
    origin: Astro.site!.href,
    dateModified: meta.updated,
    datePublished: meta.launched,
    sources,
    speakableSelector: [".verdict-text"],
  }),
  itemListLd({
    name: `Local LLMs ranked for ${device.name}`,
    items: fitting.map((r) => ({ name: r.model.name, url: `/can-i-run/${r.model.id}/${device.id}` })),
    origin: Astro.site!.href,
  }),
  faqLd(faqs),
  ...(topPick
    ? [
        howToLd({
          name: `How to run a local LLM on ${device.name}`,
          description: `Install a runtime, pick a model that fits ${device.name}'s ~${usable} GB usable memory, and run it locally.`,
          url: path,
          origin: Astro.site!.href,
          steps: [
            {
              name: `Install ${tool?.beginner.name ?? "Ollama"}`,
              text: `Install ${tool?.beginner.name ?? "Ollama"} on ${platformLabel(platform)}.${tool?.beginner.why ? ` ${tool.beginner.why}.` : ""} It downloads model weights for you and runs them from one command.`,
            },
            {
              name: "Pick a model that fits",
              text: `${device.name} has about ${usable} GB usable for a model. ${topPick.model.name} is the strongest that runs comfortably, using ~${topPick.result.estimate?.totalGb} GB at ${topPick.result.quant ? QUANT_LABEL[topPick.result.quant] : "Q4_K_M"}. Stay under ~${usable} GB.`,
            },
            {
              name: `Run ${topPick.model.name}`,
              text: topPick.model.ollama_tag
                ? `Run "ollama run ${topPick.model.ollama_tag}" in a terminal. The weights download once, then a local chat session starts. Everything stays on ${device.name}.`
                : `Load ${topPick.model.name} in ${tool?.beginner.name ?? "your runtime"} and start a local chat session. Everything stays on ${device.name}.`,
            },
          ],
        }),
      ]
    : []),
];
---

<Base title={title} description={description} path={path} jsonLd={jsonLd} ogImage={`/og/rig/${device.id}.png`} mdPath={`/best-llm-for/${device.id}.md`} ogTitle={`Best local LLMs for ${device.name}`} ogType="article" articleModified={meta.updated} ogImageAlt={`Best local LLMs for ${device.name} ranked by compatibility`}>
  <div class="mx-auto max-w-3xl px-4 py-8">
    <Breadcrumbs items={[{ name: "Home", url: "/" }, { name: "Devices", url: "/best-llm-for" }, { name: device.name, url: path }]} />

    <p class="bp-eyebrow mt-4">
      <span class="bp-dot" aria-hidden="true"></span>
      Device profile &middot; {platformLabel(platform)}
    </p>
    <h1 class="mt-3 flex items-center gap-3 text-balance text-3xl font-bold tracking-tight sm:text-4xl">
      <EntityIcon device={device.category} size={28} class="text-muted-foreground" />
      <span>Best local LLMs for {device.name}</span>
    </h1>
    <p class="mt-4 text-pretty text-lg text-muted-foreground">
      {device.name} has <strong class="text-foreground">~{usable} GB</strong> usable for model weights and runs
      <strong class="text-foreground">{fitting.length}</strong> of {ranked.length} popular models.
      {tool && <> Best tool: <strong class="text-foreground">{tool.beginner.name}</strong>.</>}
    </p>

    <div class="bp-wire mt-5" aria-hidden="true"></div>

    <dl class="bp-stat-grid mt-4">
      <div class="bp-stat-item">
        <dt class="bp-stat-label">Usable memory</dt>
        <dd class="bp-stat-val">~{usable} GB</dd>
      </div>
      <div class="bp-stat-item">
        <dt class="bp-stat-label">Models run</dt>
        <dd class="bp-stat-val">{fitting.length}</dd>
      </div>
      <div class="bp-stat-item">
        <dt class="bp-stat-label">Too large</dt>
        <dd class="bp-stat-val">{notFitting.length}</dd>
      </div>
      {topPick && (
        <div class="bp-stat-item">
          <dt class="bp-stat-label">Top pick</dt>
          <dd class="bp-stat-val bp-stat-yes">{topPick.model.params_b}B</dd>
        </div>
      )}
    </dl>

    {topPick && (
      <div class="bp-panel mt-6">
        <div class="bp-panel-header">
          <span class="bp-panel-label">Top pick</span>
          <span class="bp-panel-label">{topPick.result.quant ? QUANT_LABEL[topPick.result.quant] : "Q4_K_M"}</span>
        </div>
        <div class="p-4">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <a href={`/can-i-run/${topPick.model.id}/${device.id}`} class="text-xl font-bold hover:underline">{topPick.model.name}</a>
            <VerdictBadge verdict={topPick.result.verdict} />
          </div>
          <p class="verdict-text mt-1 text-sm text-muted-foreground">{topPick.result.reason}</p>
        </div>
      </div>
    )}

    <section class="mt-8">
      <h2 class="mb-3 text-lg font-semibold">Runs on {device.name}</h2>
      <div class="bp-panel overflow-hidden">
        <div class="bp-panel-header">
          <span class="bp-panel-label">Compatible models</span>
          <span class="bp-panel-label">{fitting.length} total</span>
        </div>
        <ul class="divide-y divide-border">
          {fitting.map((r) => (
            <li>
              <a href={`/can-i-run/${r.model.id}/${device.id}`} class="flex items-center gap-3 px-4 py-3 transition-colors hover:bg-[color-mix(in_oklch,var(--color-brand)_6%,transparent)]">
                <EntityIcon maker={r.model.family} size={18} class="text-muted-foreground shrink-0" />
                <div class="min-w-0 flex-1">
                  <div class="truncate text-sm font-medium">{r.model.name}</div>
                  <div class="bp-stat-label mt-0.5">{r.model.params_b}B{r.model.is_moe ? ` MoE` : ""} &middot; ~{r.result.estimate?.totalGb} GB at {r.result.quant ? QUANT_LABEL[r.result.quant] : "Q4_K_M"}</div>
                </div>
                <VerdictBadge verdict={r.result.verdict} />
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {notFitting.length > 0 && (
      <section class="mt-8">
        <h2 class="bp-section-label mb-3">Too large for this device</h2>
        <div class="flex flex-wrap gap-2">
          {notFitting.map((r) => (
            <a href={`/can-i-run/${r.model.id}/${device.id}`} class="rounded-[3px] border border-border px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:border-[color-mix(in_oklch,var(--color-brand)_45%,transparent)] hover:text-foreground">{r.model.name}</a>
          ))}
        </div>
      </section>
    )}

    {tool && (
      <section class="mt-8">
        <h2 class="mb-3 text-lg font-semibold">Best way to run models on {platformLabel(platform)}</h2>
        <div class="bp-panel">
          <div class="bp-panel-header">
            <span class="bp-panel-label">Runtime guide</span>
            <span class="bp-panel-label">{platformLabel(platform)}</span>
          </div>
          <div class="p-4 space-y-2">
            <p class="text-sm text-muted-foreground"><strong class="text-foreground">Beginner:</strong> {tool.beginner.name}, {tool.beginner.why}</p>
            <p class="text-sm text-muted-foreground"><strong class="text-foreground">Power user:</strong> {tool.power.name}, {tool.power.why}</p>
            <p class="text-sm text-muted-foreground">{tool.gotcha}</p>
            <a href={`/tools#${platform}`} class="inline-block text-sm text-[var(--brand-ink)] hover:underline">Full {platformLabel(platform)} tool guide &rarr;</a>
          </div>
        </div>
      </section>
    )}

    <section class="mt-10">
      <h2 class="mb-3 text-lg font-semibold">FAQ</h2>
      <div class="bp-panel divide-y divide-border">
        {faqs.map((f) => (
          <div class="p-4">
            <p class="font-medium">{f.q}</p>
            <p class="mt-2 text-sm text-muted-foreground">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <Sources urls={sources} />

    <p class="mt-6 text-xs text-muted-foreground">
      Memory figures are estimates. See <a href="/methodology" class="underline">methodology</a>.
    </p>
  </div>
</Base>
