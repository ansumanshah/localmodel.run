---
import Base from "@/layouts/Base.astro";
import Detector from "@/components/Detector.tsx";
import VerdictBadge from "@/components/VerdictBadge.astro";
import EntityIcon from "@/components/EntityIcon.astro";
import {
  popularModels,
  featuredDevices,
  tools,
  platformLabel,
  models,
  devices,
  meta,
} from "@/lib/data";
import { canRun, usableGb } from "@/lib/compute";
import { faqLd, softwareAppLd, datasetLd, truncate, type FaqItem } from "@/lib/seo";

// Reference model for the "popular hardware" cards; fail loudly at build if removed.
const refModel = models.find((m) => m.id === "llama-3.1-8b");
if (!refModel) throw new Error("index.astro: reference model 'llama-3.1-8b' not found in models.json");

const path = "/";
const title = "Can I run this AI model locally? · localmodel.run";
const description = truncate(
  `Instantly check if your computer or phone can run a local LLM like Llama, DeepSeek, Qwen or Gemma, and which tool to use on Mac, Windows, Linux, iOS or Android. Free, no signup. ${models.length} models, ${devices.length} devices, validated data.`,
);

const faqs: FaqItem[] = [
  {
    q: "How do I know if my computer can run a local LLM?",
    a: `Compare the model's memory needs to your usable memory. A 7-8B model at Q4_K_M needs about 6-7 GB, so it runs on a 16 GB Mac or a 12 GB GPU. localmodel.run does this math for ${models.length} models across ${devices.length} devices.`,
  },
  {
    q: "Can I run AI models locally on a Mac?",
    a: "Yes. Apple Silicon shares unified memory, so a 16 GB Mac runs 7-8B models and a 64 GB+ Mac runs 70B. Use LM Studio (which ships MLX) for a GUI, or mlx-lm for the most speed. vLLM is not a Mac tool, it is a Linux/CUDA serving engine.",
  },
  {
    q: "Can I run an LLM on my phone?",
    a: "Yes, within limits. iPhones and Android flagships realistically run 1B-4B models. On iOS 26 use Apple's built-in Foundation Models or PocketPal AI; on Android use PocketPal AI or Google AI Edge.",
  },
  {
    q: "Which is the best tool to run models locally?",
    a: "On Mac, start with LM Studio, it ships MLX and has a GUI. On Linux, Ollama for quick chat, vLLM if you are serving traffic. On Android or iOS, PocketPal is the only real option. Each device page links the right one so you do not have to guess.",
  },
];

const jsonLd = [
  softwareAppLd(Astro.site!.href),
  datasetLd({ origin: Astro.site!.href, dateModified: meta.updated, sources: meta.sources }),
  faqLd(faqs),
];
---

<Base title={title} description={description} path={path} jsonLd={jsonLd} altLocales={["en", "es"]}>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-border/60">
    <div class="pointer-events-none absolute inset-0 -z-10 opacity-60 [background:radial-gradient(60%_50%_at_50%_-10%,color-mix(in_oklch,var(--color-brand)_18%,transparent),transparent)]"></div>
    <div class="mx-auto max-w-4xl px-4 pb-12 pt-14 text-center sm:pt-20">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-border bg-card px-3 py-1 text-xs text-muted-foreground">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-brand)]"></span>
        {models.length} models · {devices.length} devices · validated {meta.updated}
      </div>
      <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-6xl">
        Can I run this AI model <span class="text-[var(--color-brand)]">locally?</span>
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-pretty text-lg text-muted-foreground">
        Pick a model, pick your hardware. You get a yes or no, the memory math, the exact command, and which tool to actually use. Covers Mac, Windows, Linux, iOS, Android.
      </p>

      <div class="mx-auto mt-8 max-w-2xl text-left">
        <Detector client:load />
      </div>
    </div>
  </section>

  <!-- Featured models -->
  <section class="mx-auto max-w-5xl px-4 py-12">
    <div class="flex items-end justify-between">
      <h2 class="text-2xl font-bold tracking-tight">Popular models</h2>
      <a href="/can-i-run" class="text-sm text-[var(--color-brand)] hover:underline">All {models.length} models →</a>
    </div>
    <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {popularModels.map((m) => (
        <a href={`/model/${m.id}`} class="group rounded-xl border border-border bg-card p-5 transition-colors hover:border-foreground/30">
          <div class="flex items-center justify-between gap-2">
            <h3 class="flex min-w-0 items-center gap-2 font-semibold">
              <EntityIcon maker={m.family} size={18} class="text-muted-foreground" />
              <span class="truncate">{m.name}</span>
            </h3>
            <span class="shrink-0 text-xs text-muted-foreground">{m.params_b}B{m.is_moe ? " MoE" : ""}</span>
          </div>
          <p class="mt-1 text-sm text-muted-foreground">{m.q4_k_m_gb ?? "?"} GB at Q4_K_M · {m.default_context_k}k context</p>
          {m.pulls_text && <p class="mt-0.5 text-xs text-muted-foreground">{m.pulls_text} Ollama pulls</p>}
          <span class="mt-3 inline-block text-sm text-[var(--color-brand)] group-hover:underline">Requirements →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured devices -->
  <section class="border-y border-border/60 bg-card/30">
    <div class="mx-auto max-w-5xl px-4 py-12">
      <div class="flex items-end justify-between">
        <h2 class="text-2xl font-bold tracking-tight">Popular hardware</h2>
        <a href="/best-llm-for" class="text-sm text-[var(--color-brand)] hover:underline">All {devices.length} devices →</a>
      </div>
      <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {featuredDevices.map((d) => {
          const best = canRun(refModel, d);
          return (
            <a href={`/best-llm-for/${d.id}`} class="group rounded-xl border border-border bg-card p-5 transition-colors hover:border-foreground/30">
              <div class="flex items-center justify-between gap-2">
                <h3 class="flex min-w-0 items-center gap-2 font-semibold">
                  <EntityIcon device={d.category} size={18} class="text-muted-foreground" />
                  <span class="truncate">{d.name}</span>
                </h3>
                <span class="shrink-0 text-xs text-muted-foreground">~{usableGb(d)} GB</span>
              </div>
              <div class="mt-2 flex items-center gap-2 text-sm text-muted-foreground">
                <span>Llama 3.1 8B:</span>
                <VerdictBadge verdict={best.verdict} />
              </div>
              <span class="mt-3 inline-block text-sm text-[var(--color-brand)] group-hover:underline">Best models →</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="mx-auto max-w-5xl px-4 py-12">
    <h2 class="text-2xl font-bold tracking-tight">How it works</h2>
    <div class="mt-5 grid gap-4 sm:grid-cols-3">
      {[
        { n: "1", t: "Real sizes", d: "Quant sizes come from Ollama and HuggingFace GGUF repos, not guesses. Every number is sourced." },
        { n: "2", t: "Honest memory math", d: "We add KV cache and runtime overhead, and use realistic usable memory (Apple unified ~70%, GPU VRAM minus driver)." },
        { n: "3", t: "The right tool", d: "Every platform has a different winner. MLX on Mac, CUDA on Windows, vLLM on Linux, PocketPal on phones. Wrong choice and you lose half your tokens per second." },
      ].map((s) => (
        <div class="rounded-xl border border-border bg-card p-5">
          <div class="grid h-8 w-8 place-items-center rounded-lg bg-[var(--color-brand)] font-bold text-[oklch(0.18_0.01_270)]">{s.n}</div>
          <h3 class="mt-3 font-semibold">{s.t}</h3>
          <p class="mt-1 text-sm text-muted-foreground">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Platform tools -->
  <section class="border-t border-border/60 bg-card/30">
    <div class="mx-auto max-w-5xl px-4 py-12">
      <div class="flex items-end justify-between">
        <h2 class="text-2xl font-bold tracking-tight">Best tool per platform</h2>
        <a href="/tools" class="text-sm text-[var(--color-brand)] hover:underline">Full guide →</a>
      </div>
      <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        {tools.map((t) => (
          <a href={`/tools#${t.platform}`} class="rounded-xl border border-border bg-card p-4 transition-colors hover:border-foreground/30">
            <div class="flex items-center gap-1.5 text-xs font-medium uppercase tracking-wide text-muted-foreground">
              <EntityIcon os={t.platform} size={14} />
              {platformLabel(t.platform)}
            </div>
            <div class="mt-1 font-semibold">{t.beginner.name}</div>
            <div class="mt-1 text-xs text-muted-foreground">power: {t.power.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 py-12">
    <h2 class="text-2xl font-bold tracking-tight">Frequently asked</h2>
    <div class="mt-5 divide-y divide-border rounded-xl border border-border bg-card">
      {faqs.map((f) => (
        <div class="p-5">
          <p class="font-medium">{f.q}</p>
          <p class="mt-2 text-sm text-muted-foreground">{f.a}</p>
        </div>
      ))}
    </div>
    <p class="mt-6 text-center text-sm text-muted-foreground">
      Estimates, not guarantees. See <a href="/methodology" class="underline">how we calculate</a> and our sources.
    </p>
  </section>
</Base>
