---
import Base from "@/layouts/Base.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import EntityIcon from "@/components/EntityIcon.astro";
import { models, modelsBySize, imageModels, videoModels, audioModels, allModels, devices, meta } from "@/lib/data";
import { modalityNeed } from "@/lib/compute-mm";
import { breadcrumbLd, itemListLd, truncate } from "@/lib/seo";

const mediaSections = [
  { title: "Image generation", list: imageModels, accent: "var(--modality-image)" },
  { title: "Video generation", list: videoModels, accent: "var(--modality-video)" },
  { title: "Audio & voice", list: audioModels, accent: "var(--modality-audio)" },
].filter((s) => s.list.length > 0);

const byFamily = new Map<string, typeof models>();
for (const m of [...modelsBySize].sort((a, b) => a.family.localeCompare(b.family))) {
  const key = m.family;
  byFamily.set(key, [...(byFamily.get(key) ?? []), m]);
}

const path = "/can-i-run";
const title = "Can I run this AI model locally? LLMs, image, video, audio · localmodel.run";
const description = truncate(
  `Pick from ${allModels.length} local AI models: ${models.length} text LLMs (Llama, Qwen, DeepSeek, Gemma) plus image (FLUX, SDXL), video (Wan, LTX) and audio (Whisper, Kokoro). See which Mac, PC GPU or phone runs each, with sizes and the right tool.`,
);
const jsonLd = [
  breadcrumbLd([{ name: "Home", url: "/" }, { name: "Models", url: path }], Astro.site!.href),
  itemListLd({ name: "Local AI models", items: allModels.map((m) => ({ name: m.name, url: `/model/${m.id}` })), origin: Astro.site!.href }),
];
---

<Base title={title} description={description} path={path} jsonLd={jsonLd}>
  <!-- Intro band -->
  <section class="hub-intro">
    <div class="hub-intro-inner">
      <Breadcrumbs items={[{ name: "Home", url: "/" }, { name: "Models", url: path }]} />
      <p class="eyebrow mt-4 stagger" style="--delay:0ms">
        <span class="dot" aria-hidden="true"></span>
        Model catalog
      </p>
      <h1 class="mt-3 text-balance text-3xl font-bold tracking-tight sm:text-4xl stagger" style="--delay:60ms">
        Browse {allModels.length} local AI <span class="accent">models</span>
      </h1>
      <p class="mt-4 max-w-2xl text-pretty text-lg text-muted-foreground stagger" style="--delay:130ms">
        {allModels.length} local AI models across text, image, video and audio, each validated against vendor specs, HuggingFace and tool benchmarks ({meta.updated}). Pick one to see its requirements and which of {devices.length} devices can run it.
      </p>
      <div class="wire mt-6" aria-hidden="true"></div>
      <dl class="stat-grid mt-4 stagger" style="--delay:200ms">
        <div class="stat"><dt class="stat-label">Text LLMs</dt><dd class="stat-val">{models.length}</dd></div>
        <div class="stat"><dt class="stat-label">All models</dt><dd class="stat-val">{allModels.length}</dd></div>
        <div class="stat"><dt class="stat-label">Devices</dt><dd class="stat-val">{devices.length}</dd></div>
      </dl>
    </div>
  </section>

  <!-- Model catalog -->
  <div class="mx-auto max-w-5xl px-4 pb-12 pt-8">
    <div class="space-y-8">
      {[...byFamily.entries()].map(([family, list]) => (
        <section>
          <h2 class="section-label mb-3">{family}</h2>
          <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
            {list.map((m) => (
              <li>
                <a
                  href={`/model/${m.id}`}
                  class="panel flex items-center justify-between px-4 py-3 transition-colors hover:border-[color-mix(in_oklch,var(--color-brand)_45%,transparent)]"
                >
                  <div class="flex min-w-0 items-center gap-2.5">
                    <EntityIcon maker={m.family} size={20} class="text-muted-foreground" />
                    <div class="min-w-0">
                      <div class="truncate text-sm font-semibold text-foreground" transition:name={`model-name-${m.id}`}>{m.name}</div>
                      <div class="mt-0.5 font-mono text-[11px] uppercase tracking-wide">
                        <span class="text-muted-foreground">{m.params_b}B{m.is_moe ? " MoE" : ""}</span>
                        <span class="text-muted-foreground/50"> &middot; </span>
                        <span class="font-semibold text-[var(--brand-ink)]">{m.q4_k_m_gb ?? "?"} GB</span>
                        <span class="text-muted-foreground"> Q4</span>
                      </div>
                    </div>
                  </div>
                  <span class="text-[var(--brand-ink)] opacity-60">&rarr;</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}

      {mediaSections.map((section) => (
        <section style={`--accent: ${section.accent}`}>
          <h2 class="section-label mb-3" style="color: var(--accent)">{section.title}</h2>
          <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
            {section.list.map((m) => {
              const need = modalityNeed(m);
              const params = m.params_b < 1 ? `${Math.round(m.params_b * 1000)}M` : `${m.params_b}B`;
              const sub = m.audio
                ? `${m.audio.task} · ${params} · ~${need?.neededGb} GB`
                : `${params} ${(m.image ?? m.video)?.arch.toUpperCase()} · ~${need?.neededGb} GB at ${need?.quantLabel}`;
              return (
                <li>
                  <a
                    href={`/model/${m.id}`}
                    class="panel flex items-center justify-between border-l-[3px] px-4 py-3 transition-colors hover:border-[color-mix(in_oklch,var(--accent)_55%,transparent)]"
                    style="border-left-color: var(--accent)"
                  >
                    <div class="flex min-w-0 items-center gap-2.5">
                      <EntityIcon maker={m.family} size={20} class="text-muted-foreground" />
                      <div class="min-w-0">
                        <div class="truncate text-sm font-medium" transition:name={`model-name-${m.id}`}>{m.name}</div>
                        <div class="stat-label mt-0.5">{sub}</div>
                      </div>
                    </div>
                    <span class="opacity-70" style="color: var(--accent)">&rarr;</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </div>

    <section class="mt-12 border-t border-border/60 pt-8">
      <h2 class="section-label mb-3">Browse by device</h2>
      <ul class="flex flex-wrap gap-2">
        {devices.map((d) => (
          <li>
            <a href={`/best-llm-for/${d.id}`} class="inline-flex items-center gap-1.5 rounded-md border border-border bg-card px-2.5 py-1.5 text-xs text-muted-foreground transition-colors hover:border-foreground/30 hover:text-foreground">
              <EntityIcon device={d.category} size={14} class="text-muted-foreground" />
              {d.name}
            </a>
          </li>
        ))}
      </ul>
      <p class="mt-3 text-sm text-muted-foreground">
        Or get a <a href="/rig" class="text-[var(--brand-ink)] hover:underline">Rig Score</a> for your exact machine.
      </p>
    </section>
  </div>
</Base>

<style>
  /* Scoped layout for the intro band only. */
  .hub-intro {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    /* transparent so the page background runs through the intro band (an
       opaque background cut it off, leaving a hard seam below the hero). */
    border-bottom: 1px solid var(--border);
    padding: clamp(1.25rem, 4vh, 2.5rem) clamp(1rem, 4vw, 3rem);
  }
  .hub-intro-inner {
    position: relative;
    z-index: 4;
    max-width: 64rem; /* max-w-5xl — matches the catalog + header --shell */
    margin: 0 auto;
  }
</style>
