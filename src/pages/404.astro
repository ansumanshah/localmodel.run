---
import Base from "@/layouts/Base.astro";
import { featuredModels, featuredDevices } from "@/lib/data";
---

<Base title="Not found · localmodel.run" description="That page does not exist. Pick a model or device to check local AI compatibility." path="/404" noindex={true}>
  <div class="mx-auto max-w-2xl px-4 py-20 text-center">
    <div class="text-6xl font-bold tracking-tight">404</div>
    <p class="mt-3 text-lg text-muted-foreground">That page does not exist. Try one of these instead.</p>
    <div class="mt-8 grid gap-3 text-left sm:grid-cols-2">
      <div class="rounded-xl border border-border bg-card p-4">
        <div class="text-sm font-semibold">Models</div>
        <ul class="mt-2 space-y-1">
          {featuredModels.slice(0, 4).map((m) => (
            <li><a href={`/model/${m.id}`} class="text-sm text-[var(--color-brand)] hover:underline">{m.name}</a></li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-border bg-card p-4">
        <div class="text-sm font-semibold">Devices</div>
        <ul class="mt-2 space-y-1">
          {featuredDevices.slice(0, 4).map((d) => (
            <li><a href={`/best-llm-for/${d.id}`} class="text-sm text-[var(--color-brand)] hover:underline">{d.name}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <a href="/" class="mt-8 inline-block rounded-lg bg-[var(--color-brand)] px-4 py-2 text-sm font-medium text-[oklch(0.18_0.01_270)]">Back home</a>
  </div>
</Base>
