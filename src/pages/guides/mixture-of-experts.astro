---
import Base from "@/layouts/Base.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Sources from "@/components/Sources.astro";
import { models, getModel, meta } from "@/lib/data";
import { breadcrumbLd, faqLd, techArticleLd, truncate, type FaqItem } from "@/lib/seo";

// Definitional GEO guide. Numbers come from the dataset's own params/active-params
// and the same MoE memory rule the calculator applies (memory tracks TOTAL params).
const hero = getModel("qwen3-30b-a3b")!;
const moes = models
  .filter((m) => m.is_moe && m.active_params_b != null)
  .sort((a, b) => a.params_b - b.params_b)
  .slice(0, 6);

const path = "/guides/mixture-of-experts";
const title = "Mixture of experts (MoE) explained for local LLMs · localmodel.run";
const description = truncate(
  "Why a 30B mixture-of-experts model runs at the speed of a 3B model but still needs the memory of a 30B model. The active-vs-total trick, with a worked example.",
);

const SOURCES = [
  "https://huggingface.co/docs/transformers/main/en/model_doc/mixtral",
  "https://github.com/ggml-org/llama.cpp/blob/master/tools/quantize/README.md",
  ...hero.sources.slice(0, 1),
];

const faqs: FaqItem[] = [
  {
    q: "Does a mixture-of-experts model use less memory?",
    a: "No. A MoE model only computes with a few of its experts per token, so it is fast, but every expert has to be loaded in memory in case it is needed. Memory tracks the total parameter count, not the active count. A 30B MoE needs roughly the memory of a 30B dense model.",
  },
  {
    q: "Why is a MoE model fast then?",
    a: "Because only a small slice of the weights does work on each token. A 30B model with about 3B active parameters does roughly the compute of a 3B model per token, so it generates quickly, while still having the knowledge of a much larger model spread across its experts.",
  },
  {
    q: "Should I run a MoE or a dense model?",
    a: "If you have the memory for the total size, a MoE gives you more capability per unit of speed. If memory is tight, a dense model of the same on-disk size is usually the safer fit, because the MoE's total size is what has to fit, not its fast active part.",
  },
  {
    q: "What does a tag like 30B-A3B mean?",
    a: "It is total parameters and active parameters. 30B-A3B means about 30 billion total parameters with about 3 billion active per token. The first number drives memory, the second drives speed.",
  },
];

const jsonLd = [
  breadcrumbLd(
    [
      { name: "Home", url: "/" },
      { name: "Guides", url: "/guides" },
      { name: "Mixture of experts", url: path },
    ],
    Astro.site!.href,
  ),
  techArticleLd({
    headline: "Mixture of experts (MoE) explained for local LLMs",
    description,
    url: path,
    origin: Astro.site!.href,
    dateModified: meta.updated,
    datePublished: meta.launched,
    sources: SOURCES,
    speakableSelector: [".guide-tldr"],
  }),
  faqLd(faqs),
];
---

<Base
  title={title}
  description={description}
  path={path}
  jsonLd={jsonLd}
  ogTitle="Mixture of experts explained"
  ogType="article"
  articleModified={meta.updated}
  ogImageAlt="How mixture-of-experts models trade memory for speed"
>
  <article class="mx-auto max-w-3xl px-4 py-8">
    <Breadcrumbs
      items={[
        { name: "Home", url: "/" },
        { name: "Guides", url: "/guides" },
        { name: "Mixture of experts", url: path },
      ]}
    />

    <p class="bp-eyebrow mt-4"><span class="bp-dot" aria-hidden="true"></span>Guide &middot; Architecture</p>
    <h1 class="mt-3 text-balance text-3xl font-bold tracking-tight sm:text-4xl">
      Mixture of experts, explained
    </h1>
    <p class="mt-4 text-pretty text-lg text-muted-foreground">
      Mixture-of-experts models look like a free lunch: the speed of a small model with the knowledge
      of a large one. The catch is memory, and a lot of calculators get it wrong.
    </p>

    <div class="bp-panel guide-tldr mt-6">
      <div class="bp-panel-header"><span class="bp-panel-label">The short version</span></div>
      <p class="p-4 text-sm text-muted-foreground">
        A MoE model splits its weights into many <strong class="text-foreground">experts</strong> and
        uses only a few per token. That makes it <strong class="text-foreground">fast</strong> like
        its small active part, but it needs <strong class="text-foreground">memory</strong> for its
        full total size, because every expert has to be resident.
      </p>
    </div>

    <section class="mt-8">
      <h2 class="text-xl font-semibold">Two numbers, not one</h2>
      <p class="mt-2 text-muted-foreground">
        A dense model has one parameter count that drives both speed and memory. A MoE has two: total
        parameters and active parameters. They pull in different directions.
      </p>
      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="bp-panel p-4">
          <p class="bp-stat-label">Active parameters</p>
          <p class="mt-1 text-sm text-muted-foreground">How much compute runs per token. Drives <strong class="text-foreground">speed</strong>.</p>
        </div>
        <div class="bp-panel p-4">
          <p class="bp-stat-label">Total parameters</p>
          <p class="mt-1 text-sm text-muted-foreground">Every expert, all resident. Drives <strong class="text-foreground">memory</strong>.</p>
        </div>
      </div>
    </section>

    <section class="mt-8">
      <h2 class="text-xl font-semibold">A worked example: {hero.name}</h2>
      <p class="mt-2 text-muted-foreground">
        {hero.name} has about {hero.params_b}B total parameters but activates only ~{hero.active_params_b}B
        per token. So it generates at roughly the speed of a {hero.active_params_b}B model, while
        needing the memory of a {hero.params_b}B one: about {hero.q4_k_m_gb} GB at Q4_K_M.
      </p>
      <div class="bp-panel mt-3 grid grid-cols-3 divide-x divide-border">
        <div class="p-4">
          <p class="bp-stat-label">Total</p>
          <p class="bp-stat-val mt-1 text-base">{hero.params_b}B</p>
          <p class="mt-1 text-xs text-muted-foreground">sets memory</p>
        </div>
        <div class="p-4">
          <p class="bp-stat-label">Active</p>
          <p class="bp-stat-val mt-1 text-base bp-stat-yes">~{hero.active_params_b}B</p>
          <p class="mt-1 text-xs text-muted-foreground">sets speed</p>
        </div>
        <div class="p-4">
          <p class="bp-stat-label">Q4_K_M</p>
          <p class="bp-stat-val mt-1 text-base">~{hero.q4_k_m_gb} GB</p>
          <p class="mt-1 text-xs text-muted-foreground">has to fit</p>
        </div>
      </div>
      <p class="mt-3 text-muted-foreground">
        The mistake is to size it by the active {hero.active_params_b}B and expect it to fit a small
        machine. It will not. You need room for all {hero.params_b}B.
      </p>
    </section>

    <section class="mt-8">
      <h2 class="text-xl font-semibold">MoE models, by total size</h2>
      <p class="mt-2 text-muted-foreground">
        Tracked mixture-of-experts models and the gap between what they cost in speed and in memory:
      </p>
      <div class="bp-panel mt-3 overflow-hidden">
        <div class="bp-panel-header">
          <span class="bp-panel-label">Model</span>
          <span class="bp-panel-label">total / active</span>
        </div>
        <ul class="divide-y divide-border">
          {moes.map((m) => (
            <li>
              <a href={`/model/${m.id}`} class="flex items-center justify-between px-4 py-3 transition-colors hover:bg-[color-mix(in_oklch,var(--color-brand)_6%,transparent)]">
                <span class="min-w-0 truncate text-sm font-medium">{m.name}</span>
                <span class="shrink-0 text-sm text-muted-foreground">
                  {m.params_b}B <span class="opacity-60">/</span> <span style="color:var(--color-verdict-yes)">~{m.active_params_b}B</span>
                  {m.q4_k_m_gb ? <span class="bp-stat-label"> &middot; ~{m.q4_k_m_gb} GB</span> : null}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mt-8">
      <h2 class="text-xl font-semibold">So when should you run a MoE?</h2>
      <p class="mt-2 text-muted-foreground">
        When you have the memory for the total size and want more capability without slowing down. If
        memory is the constraint, compare by on-disk size, not by the active part: a MoE's total is
        what has to fit. Check any model against your hardware from your
        <a href="/best-llm-for-ram" class="text-[var(--brand-ink)] hover:underline">memory budget</a>,
        and see the exact MoE memory rule in the
        <a href="/methodology" class="text-[var(--brand-ink)] hover:underline">methodology</a>.
      </p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-semibold">FAQ</h2>
      <div class="bp-panel mt-3 divide-y divide-border">
        {faqs.map((f) => (
          <div class="p-4">
            <p class="font-medium">{f.q}</p>
            <p class="mt-2 text-sm text-muted-foreground">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <nav class="mt-8" aria-label="More guides">
      <h2 class="bp-section-label mb-3">More guides</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/guides/quantization" class="rounded-full border border-border px-3 py-1.5 text-sm font-medium transition-colors hover:border-[color-mix(in_oklch,var(--color-brand)_45%,transparent)]">Quantization explained</a>
        <a href="/guides/vram-vs-ram" class="rounded-full border border-border px-3 py-1.5 text-sm font-medium transition-colors hover:border-[color-mix(in_oklch,var(--color-brand)_45%,transparent)]">VRAM vs RAM vs unified memory</a>
      </div>
    </nav>

    <Sources urls={SOURCES} />
  </article>
</Base>
