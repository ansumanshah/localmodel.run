---
import Base from "@/layouts/Base.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import EntityIcon from "@/components/EntityIcon.astro";
import { modelsByArena, meta } from "@/lib/data";
import { breadcrumbLd, itemListLd, techArticleLd, truncate } from "@/lib/seo";

const path = "/leaderboard";
const title = "Local LLM quality leaderboard (LMArena Elo) · localmodel.run";
const description = truncate(
  `The open models you can run locally, ranked by LMArena (Chatbot Arena) text Elo. ${modelsByArena.length} tracked local models with arena scores, each linked to its hardware requirements.`,
);
const jsonLd = [
  breadcrumbLd([{ name: "Home", url: "/" }, { name: "Leaderboard", url: path }], Astro.site!.href),
  techArticleLd({
    headline: "Local LLM quality leaderboard ranked by LMArena Elo",
    description,
    url: path,
    origin: Astro.site!.href,
    dateModified: meta.updated,
    datePublished: meta.launched,
  }),
  itemListLd({
    name: "Local LLMs ranked by LMArena Elo",
    items: modelsByArena.map((m) => ({ name: m.name, url: `/model/${m.id}` })),
    origin: Astro.site!.href,
  }),
];
---

<Base title={title} description={description} path={path} jsonLd={jsonLd}>
  <div class="mx-auto max-w-3xl px-4 py-8">
    <Breadcrumbs items={[{ name: "Home", url: "/" }, { name: "Leaderboard", url: path }]} />

    <p class="bp-eyebrow mt-4"><span class="bp-dot" aria-hidden="true"></span>Quality ranking &middot; LMArena Elo</p>
    <h1 class="mt-3 text-balance text-3xl font-bold tracking-tight sm:text-4xl">Local LLM quality leaderboard</h1>
    <p class="mt-4 text-pretty text-lg text-muted-foreground">
      Open models you can run locally, ranked by <a href="https://lmarena.ai" rel="noopener nofollow" class="underline">LMArena</a> text Elo as of {meta.updated}. Higher is better. Only models present on the arena are listed, so many small and distilled models are absent. Scores drift over time.
    </p>

    <div class="mt-6 bp-panel overflow-hidden">
      <div class="bp-panel-header">
        <span class="bp-panel-label">Model</span>
        <span class="bp-panel-label">{modelsByArena.length} entries</span>
      </div>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-[color-mix(in_oklch,var(--color-brand)_15%,transparent)]">
            <th scope="col" class="px-4 py-2.5 text-left"><span class="bp-stat-label">#</span></th>
            <th scope="col" class="px-4 py-2.5 text-left"><span class="bp-stat-label">Model</span></th>
            <th scope="col" class="px-4 py-2.5 text-right"><span class="bp-stat-label">Params</span></th>
            <th scope="col" class="px-4 py-2.5 text-right"><span class="bp-stat-label">Elo</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {modelsByArena.map((m, i) => (
            <tr class="transition-colors hover:bg-[color-mix(in_oklch,var(--color-brand)_5%,transparent)]">
              <td class="px-4 py-2.5 text-muted-foreground"><span class="num">{i + 1}</span></td>
              <td class="px-4 py-2.5">
                <div class="flex min-w-0 items-center gap-2">
                  <EntityIcon maker={m.family} size={18} class="text-muted-foreground shrink-0" />
                  <a href={`/model/${m.id}`} class="truncate font-medium hover:underline">{m.name}</a>
                  {m.is_moe && <span class="ml-1.5 bp-stat-label">MoE</span>}
                </div>
              </td>
              <td class="px-4 py-2.5 text-right text-muted-foreground"><span class="num">{m.params_b}</span>B</td>
              <td class="px-4 py-2.5 text-right"><span class="bp-stat-val text-base">{m.arena_elo}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="mt-4 text-xs text-muted-foreground">
      Source: LMArena text leaderboard, snapshot around {meta.updated}. Elo measures human preference in blind pairwise chats, not local speed. Pick the highest-Elo model your hardware can run on the <a href="/best-llm-for" class="underline">device pages</a>.
    </p>
  </div>
</Base>
